# ---------------------------------------------------------------------------
# Copy this file to ".env.local" and fill in real values.
# In Vercel, add these same keys under Project Settings > Environment Variables.
# ---------------------------------------------------------------------------

# Sanity (get these from https://www.sanity.io/manage after creating a project)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Contact / prayer form email delivery (https://resend.com — free tier)
# If RESEND_API_KEY is empty, form submissions are logged to the server console
# instead of emailed (handy for local development).
RESEND_API_KEY=
CONTACT_EMAIL=hello@teamzionlipa.org
FROM_EMAIL=onboarding@resend.dev

# Public site URL (used for sitemap / SEO). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
